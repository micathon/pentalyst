do (
gdefun (var x) do (
  set x 240;
  println "gdefun: x =" x;
  #println "gdefun: p of x =" (p x);
  p x;
  println "btm: x =" x;
);
defun (p x)(var b c d e f y) do (
  println "p: x =" x;
  set e 555;
  ++ x;
  println "p: x =" x;
  println "p: (q x)" (q x);
  #println "p: (q x),e" (q x) e;
  println "p: btm";
);
defun (q x)(var a b c d e f y)  do (
  ++ x;
  println "q: x =" x;
  set y x;
  return y;
)
