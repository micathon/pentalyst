do (
gdefun (var mygvar) do (
  p 1;
);
defun (p x)(var y z) do (
  set z true;
  set y (add x 0);
  set y (mpy x 0);
  set y (minus x 0);
  set y (div x 1);
  set y (idiv x 1);
  set y (mod x 1);
  set y (shl x 0);
  set y (shr x 0);
  set y (shru x 0);
  set y (eq x 0);
  set y (ne x 0);
  set y (lt x 0);
  set y (le x 0);
  set y (ge x 0);
  set y (gt x 0);
  set y (andbitz x 0);
  set y (orbitz x 0);
  set y (xorbitz x 0);
  set y (notbitz x);
  set y (and z true);
  set y (or z true);
  set y (xor z true);
  set y (not z);
{#
	case MPY:
	case XOR:
	case ANDBITZ:
	case ORBITZ:
	case XORBITZ:
	case MINUS:
	case DIV:
	case IDIV:
	case MOD:
	case SHL:
	case SHR:
	case SHRU:
	case EQ:
	case NE:
	case LT:
	case LE:
	case GE:
	case GT:
	case NOT:
	case NOTBITZ:
	case AND:
	case OR:
#}
);
)
